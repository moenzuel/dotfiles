if status is-interactive
    if type -q mise
        {{ lookPath "mise" }} activate fish | source
    end

    if type -q starship
        {{ lookPath "starship" }} init fish | source
    end
end

if type -q chezmoi
    alias cm {{ lookPath "chezmoi" }}
end

{{ if eq .chezmoi.os "linux" }}
{{   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
[core]
	alias op op.exe
{{   end }}
{{ end }}
